<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<add name="CarRentalDb"
			 connectionString="Provider=Microsoft.ACE.OLEDB.12.0;Data Source=|DataDirectory|\CarRental.accdb;"
			 providerName="System.Data.OleDb" />
	</connectionStrings>

	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
	</startup>
</configuration>